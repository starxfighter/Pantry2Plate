# =============================================================================
# Pantry-to-Plate — .gitignore
# =============================================================================


# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/
.ruff_cache/


# -----------------------------------------------------------------------------
# Logs & Checkpoints
# -----------------------------------------------------------------------------
*.log
*.checkpoint


# -----------------------------------------------------------------------------
# Data (persistent pantry DB)
# -----------------------------------------------------------------------------
data/*.db


# -----------------------------------------------------------------------------
# Frontend / Node (if tooling is added later)
# -----------------------------------------------------------------------------
node_modules/
.npm/


# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini


# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
