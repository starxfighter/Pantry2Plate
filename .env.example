# =============================================================================
# Pantry-to-Plate — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------

# Your Anthropic API key (required)
ANTHROPIC_API_KEY=

# Claude model to use for all agents
# Default: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514


# -----------------------------------------------------------------------------
# Tavily Search API
# -----------------------------------------------------------------------------

# Your Tavily API key (required)
# Sign up at https://tavily.com
TAVILY_API_KEY=

# Maximum number of results to return per Tavily search query
# Default: 5
TAVILY_MAX_RESULTS=5


# -----------------------------------------------------------------------------
# Spoonacular Recipe API
# -----------------------------------------------------------------------------

# Your Spoonacular API key (required)
# Sign up at https://spoonacular.com/food-api
SPOONACULAR_API_KEY=

# Maximum number of recipes to return per Spoonacular search query
# Default: 10
SPOONACULAR_MAX_RESULTS=10

# Set to false to skip Spoonacular entirely (e.g. when free-tier daily quota is exhausted).
# Tavily will be used as the sole recipe source.
# Default: true
SPOONACULAR_ENABLED=true


# -----------------------------------------------------------------------------
# LangSmith Observability
# -----------------------------------------------------------------------------

# Your LangSmith API key (required for tracing)
# Sign up at https://smith.langchain.com
LANGSMITH_API_KEY=

# LangSmith project name — traces will be grouped under this project
# Default: pantry-to-plate
LANGSMITH_PROJECT=pantry-to-plate

# Set to true to enable LangSmith trace logging
# Default: true
LANGCHAIN_TRACING_V2=true


# -----------------------------------------------------------------------------
# FastAPI Application Server
# -----------------------------------------------------------------------------

# Host address the FastAPI server binds to
# Default: 0.0.0.0
APP_HOST=0.0.0.0

# Port the FastAPI server listens on
# Default: 8000
APP_PORT=8000

# Comma-separated list of allowed CORS origins
# Use * to allow all origins (not recommended in production)
# Example: http://localhost:3000,https://myapp.example.com
# Default: *
CORS_ORIGINS=*


# -----------------------------------------------------------------------------
# Application Behaviour
# -----------------------------------------------------------------------------

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# Total number of recipe candidates fetched (across all sources) before scoring
# Default: 15
MAX_RECIPE_RESULTS=15

# Number of top-ranked recipes to return to the user after scoring
# Default: 10
TOP_RECIPE_COUNT=10


# -----------------------------------------------------------------------------
# Scoring & Deduplication Thresholds
# -----------------------------------------------------------------------------

# Minimum fuzzy-match score (0–100) for an ingredient to count as a match
# Higher values require closer ingredient name similarity
# Default: 80
INGREDIENT_MATCH_THRESHOLD=80

# Minimum similarity score (0–100) above which two recipes are considered
# duplicates; the lower-ranked duplicate is dropped from results
# Default: 85
RECIPE_DEDUP_THRESHOLD=85


# -----------------------------------------------------------------------------
# MCP Server Settings
# -----------------------------------------------------------------------------

# Seconds to wait for each MCP server subprocess to become ready at startup
# Default: 10
MCP_SERVER_STARTUP_TIMEOUT=10

# Automatically restart MCP server subprocesses if they exit unexpectedly
# Default: true
MCP_AUTO_RESTART=true
